# Sepolia testnet (optional)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
SEPOLIA_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Base mainnet deploy
BASE_RPC_URL=https://mainnet.base.org
BASE_PRIVATE_KEY=0xYOUR_BASE_PRIVATE_KEY

# Frontend — set after deploying
VITE_PREDICTIONS_ADDRESS=0xYOUR_PREDICTIONS_CONTRACT
VITE_MATCH_REGISTRY_ADDRESS=0xYOUR_MATCH_REGISTRY_CONTRACT

# Optional: fix tournament start time (ISO string)
# VITE_FLWC_TOURNAMENT_START_AT=2025-06-10T18:00:00.000Z
